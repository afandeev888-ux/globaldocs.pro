# ========================================
# РЕДИРЕКТЫ HTTP → HTTPS и WWW → БЕЗ WWW
# Эти правила ДОЛЖНЫ быть первыми!
# ========================================
RewriteEngine On

# WWW → без WWW (HTTP + HTTPS)
RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^(.*)$ https://%1/$1 [L,R=301]

# HTTP → HTTPS (учитываем прокси хостинга)
RewriteCond %{HTTPS} off
RewriteCond %{HTTP:X-Forwarded-Proto} !https
RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [L,R=301]

# ========================================
# РЕДИРЕКТ /ru/ → / (RU теперь в корне)
# ========================================
RewriteCond %{REQUEST_URI} ^/ru/(.*)$
RewriteRule ^ru/(.*)$ /$1 [L,R=301]

# ========================================
# ЯЗЫКОВОЙ РЕДИРЕКТ (только для корня)
# Если пользователь уже выбрал язык (кука lang_choice) — honour choice, не редиректим.
# Если куки нет — редирект по Accept-Language браузера.
# Немецкий → /de/, Английский → /en/, Остальные → / (русский)
# Стоит ПОСЛЕ HTTPS-редиректа, чтобы не было двойных переходов
# ========================================

# Пользователь вручную выбрал русский — остаёмся на /
RewriteCond %{HTTP_COOKIE} lang_choice=ru [NC]
RewriteCond %{REQUEST_URI} ^/$
RewriteRule ^$ - [L]

# Пользователь вручную выбрал английский → /en/
RewriteCond %{HTTP_COOKIE} lang_choice=en [NC]
RewriteCond %{REQUEST_URI} ^/$
RewriteRule ^$ /en/ [R=302,L]

# Пользователь вручную выбрал немецкий → /de/
RewriteCond %{HTTP_COOKIE} lang_choice=de [NC]
RewriteCond %{REQUEST_URI} ^/$
RewriteRule ^$ /de/ [R=302,L]

# Авто-редирект по Accept-Language (только если НЕТ куки lang_choice)
RewriteCond %{HTTP_COOKIE} !lang_choice= [NC]
RewriteCond %{HTTP:Accept-Language} ^de [NC]
RewriteCond %{REQUEST_URI} ^/$
RewriteCond %{QUERY_STRING} ^$
RewriteRule ^$ /de/ [R=302,L]

RewriteCond %{HTTP_COOKIE} !lang_choice= [NC]
RewriteCond %{HTTP:Accept-Language} ^en [NC]
RewriteCond %{REQUEST_URI} ^/$
RewriteCond %{QUERY_STRING} ^$
RewriteRule ^$ /en/ [R=302,L]

# ========================================
# 301 РЕДИРЕКТЫ ДЛЯ ДУБЛИРУЮЩИХСЯ СТАТЕЙ БЛОГА
# Консолидация: слабые дубликаты → лучшие статьи
# ========================================

# Справка о несудимости: kak-poluchit → spravka (RU)
Redirect 301 /blog/kak-poluchit-spravku-ob-otsutstvii-sudimosti-iz-za-granicy/ https://globaldocs.pro/blog/spravka-o-nesudimosti-iz-za-granitsy/

# Criminal record: how-to-get → criminal-record-certificate (EN)
Redirect 301 /en/blog/how-to-get-criminal-record-certificate-from-abroad/ https://globaldocs.pro/en/blog/criminal-record-certificate-from-abroad/

# Führungszeugnis: beantragen → aus-dem-ausland (DE)
Redirect 301 /de/blog/fuehrungszeugnis-aus-dem-ausland-beantragen/ https://globaldocs.pro/de/blog/fuehrungszeugnis-aus-dem-ausland/

# Израиль: emigraciya → pereezd (RU)
Redirect 301 /blog/dokumenty-dlya-emigracii-v-izrail-2026/ https://globaldocs.pro/blog/dokumenty-dlya-pereezda-v-izrail-iz-rossii/

# Israel: emigration → moving-from-russia (EN)
Redirect 301 /en/blog/documents-for-emigration-to-israel-2026/ https://globaldocs.pro/en/blog/documents-for-moving-to-israel-from-russia/

# Israel: auswanderung → umzug-aus-russland (DE)
Redirect 301 /de/blog/dokumente-fuer-auswanderung-nach-israel-2026/ https://globaldocs.pro/de/blog/dokumente-fuer-umzug-nach-israel-aus-russland/

# ========================================
# ЗАГОЛОВКИ БЕЗОПАСНОСТИ
# ========================================

# HSTS - форсирование HTTPS (1 год, без preload пока)
Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"

# Безопасность
Header always set X-Content-Type-Options "nosniff"
Header always set X-Frame-Options "SAMEORIGIN"
Header always set Referrer-Policy "strict-origin-when-cross-origin"
Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"

# ========================================
# КЭШИРОВАНИЕ СТАТИКИ
# ========================================
<IfModule mod_expires.c>
  ExpiresActive On
  # Картинки - 1 месяц
  ExpiresByType image/jpeg "access plus 1 month"
  ExpiresByType image/png "access plus 1 month"
  ExpiresByType image/gif "access plus 1 month"
  ExpiresByType image/x-icon "access plus 1 month"
  ExpiresByType image/webp "access plus 1 month"
  ExpiresByType image/svg+xml "access plus 1 month"
  # CSS/JS - 1 неделя
  ExpiresByType text/css "access plus 1 week"
  ExpiresByType application/javascript "access plus 1 week"
  # Шрифты - 1 год
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType application/font-woff "access plus 1 year"
  ExpiresByType application/font-woff2 "access plus 1 year"
  # HTML - не кэшировать
  ExpiresByType text/html "access plus 0 seconds"
</IfModule>

# ========================================
# СЖАТИЕ GZIP
# ========================================
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html
  AddOutputFilterByType DEFLATE text/css
  AddOutputFilterByType DEFLATE application/javascript
  AddOutputFilterByType DEFLATE application/json
  AddOutputFilterByType DEFLATE text/xml
  AddOutputFilterByType DEFLATE application/xml
  AddOutputFilterByType DEFLATE image/svg+xml
  AddOutputFilterByType DEFLATE text/javascript
  AddOutputFilterByType DEFLATE application/ld+json
</IfModule>
