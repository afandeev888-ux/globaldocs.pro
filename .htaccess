# Редирект HTTP → HTTPS
RewriteEngine On

# Проверяем, что запрос не HTTPS
RewriteCond %{HTTPS} off

# Редирект на HTTPS с тем же хостом и URI
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Редирект www → без www (выберите один вариант)

# Вариант А: www → без www (рекомендуется)
RewriteCond %{HTTP_HOST} ^www\.globaldocs\.pro$ [NC]
RewriteRule ^(.*)$ https://globaldocs.pro/$1 [L,R=301]

# Вариант Б: без www → www (раскомментируйте если нужен www)
# RewriteCond %{HTTP_HOST} ^globaldocs\.pro$ [NC]
# RewriteRule ^(.*)$ https://www.globaldocs.pro/$1 [L,R=301]

# HSTS - форсирование HTTPS в браузере (1 год)
Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

# Безопасность
Header always set X-Content-Type-Options "nosniff"
Header always set X-Frame-Options "SAMEORIGIN"
Header always set X-XSS-Protection "1; mode=block"

# Кэширование статики
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
</IfModule>

# Сжатие GZIP
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json
</IfModule>
